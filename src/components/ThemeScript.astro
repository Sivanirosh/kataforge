<script is:inline>
  (function () {
    try {
      if (localStorage.getItem('kataforge-theme') === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    } catch (_e) {}
  })();
</script>
<style is:inline>
  html {
    color-scheme: dark;
    background: #09090e;
    color: #edecf4;
  }

  html[data-theme='light'] {
    color-scheme: light;
    background: #fafafa;
    color: #18181b;
  }

  body {
    margin: 0;
    min-height: 100%;
    background: inherit;
    color: inherit;
  }

  .cursus-boot-shell {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: inherit;
    pointer-events: none;
  }
</style>
