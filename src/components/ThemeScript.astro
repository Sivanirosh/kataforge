<script is:inline>
  (function () {
    try {
      if (localStorage.getItem('kataforge-theme') === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    } catch (_e) {}
  })();
</script>
<style is:inline>
  /* First-paint colors, inlined so there is no flash before tokens.css loads.
     These hexes mirror --bg / --text in src/styles/tokens.css. Keep in sync:
     if you change --bg / --text there, update these four values. */
  html {
    color-scheme: dark;
    background: #09090e; /* mirrors --bg  (dark) */
    color: #edecf4;      /* mirrors --text (dark) */
  }

  html[data-theme='light'] {
    color-scheme: light;
    background: #fafafa; /* mirrors --bg  (light) */
    color: #18181b;      /* mirrors --text (light) */
  }

  body {
    margin: 0;
    min-height: 100%;
    background: inherit;
    color: inherit;
  }

  .cursus-boot-shell {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: #09090e;
    pointer-events: none;
  }

  html[data-theme='light'] .cursus-boot-shell {
    background: #fafafa;
  }
</style>
