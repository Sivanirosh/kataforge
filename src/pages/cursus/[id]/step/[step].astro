---
import CursusShell from '../../../../components/CursusShell';
import FontLinks from '../../../../components/FontLinks.astro';
import ThemeScript from '../../../../components/ThemeScript.astro';
import { loadKataForgeConfig } from '../../../../lib/loadConfig';
import { loadLessonMap } from '../../../../lib/loadLessons';
import { loadKataMap } from '../../../../lib/loadKatas';
import '../../../../styles/cursus.css';

export async function getStaticPaths() {
  const { loadAllCursus } = await import('../../../../lib/loadCursus');
  const all = await loadAllCursus();
  const paths = [];
  for (const cursus of all) {
    let stepCount = 0;
    for (const mod of cursus.modules) {
      stepCount += mod.steps.length;
    }
    for (let step = 0; step < stepCount; step += 1) {
      paths.push({
        params: { id: cursus.id, step: String(step) },
        props: { cursus, stepIndex: step },
      });
    }
  }
  return paths;
}

const { cursus, stepIndex } = Astro.props;
const config = await loadKataForgeConfig();
const lessonMap = await loadLessonMap();
const kataMap = await loadKataMap();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ThemeScript />
    <FontLinks />
    <title>{cursus.title} · Step {stepIndex + 1} · {config.branding.title}</title>
  </head>
  <body class="cursus-page">
    <CursusShell
      client:only="react"
      cursus={cursus}
      currentGlobalIndex={stepIndex}
      lessonMap={lessonMap}
      kataMap={kataMap}
      judgeConfig={config.judge}
      brandingTitle={config.branding.title}
    />
  </body>
</html>
