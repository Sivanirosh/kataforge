---
import FontLinks from '../../components/FontLinks.astro';
import ProblemPage from '../../components/ProblemPage';
import ThemeScript from '../../components/ThemeScript.astro';
import UIVersionScript from '../../components/UIVersionScript.astro';
import UIVersionToggle from '../../components/UIVersionToggle';
import { loadKataForgeConfig } from '../../lib/loadConfig';
import { loadAllKatas } from '../../lib/loadKatas';
import '../../styles/global.css';
import '../../styles/global-v2.css';

export async function getStaticPaths() {
  const katas = await loadAllKatas();
  return katas.map((kata) => ({
    params: { id: kata.id },
    props: { kata },
  }));
}

const { kata } = Astro.props;
const config = await loadKataForgeConfig();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ThemeScript />
    <UIVersionScript />
    <FontLinks />
    <title>{kata.title} · {config.branding.title}</title>
  </head>
  <body>
    <ProblemPage
      client:only="react"
      kataId={kata.id}
      builtinKata={kata}
      judgeConfig={config.judge}
      brandingTitle={config.branding.title}
    />
    <UIVersionToggle client:load />
  </body>
</html>
