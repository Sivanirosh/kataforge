---
import '../styles/global.css';
import AssessmentStartActions from '../components/AssessmentStartActions';
import FontLinks from '../components/FontLinks.astro';
import SiteNav from '../components/SiteNav.astro';
import ThemeScript from '../components/ThemeScript.astro';
import { loadKataForgeConfig } from '../lib/loadConfig';
import { loadAssessments } from '../lib/loadAssessments';
import { loadAllCursus } from '../lib/loadCursus';
import { loadAllKatas } from '../lib/loadKatas';
import { countCursusSteps } from '../lib/cursusSteps';

const config = await loadKataForgeConfig();
const assessments = await loadAssessments();
const cursusList = await loadAllCursus();
const katas = await loadAllKatas();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ThemeScript />
    <FontLinks />
    <title>{config.branding.title}</title>
  </head>
  <body>
    <SiteNav title={config.branding.title} />

    <section class="hero">
      <div class="hero-inner">
        <div class="hero-badge">Kata Practice Tool</div>
        <h1 class="hero-title">{config.branding.title}</h1>
        <p class="hero-tagline">{config.branding.tagline}</p>
        <a class="btn btn-primary btn-lg" href="#assessments">Browse Assessments</a>
      </div>
    </section>

    <main class="landing page-main">
      <section class="landing-section" id="cursus">
        <div class="section-header">
          <h2>Cursus</h2>
        </div>
        <ul class="card-list">
          {cursusList.map((cursus) => (
            <li class="card">
              <h3>{cursus.title}</h3>
              <p>
                {cursus.modules.length} modules · {countCursusSteps(cursus)} steps
              </p>
              <a class="btn btn-primary" href={`/cursus/${cursus.id}`}>
                Open
              </a>
            </li>
          ))}
        </ul>
      </section>

      <section class="landing-section" id="assessments">
        <div class="section-header">
          <h2>Assessments</h2>
        </div>
        <ul class="card-list">
          {assessments.map((assessment) => (
            <li class="card">
              <h3>{assessment.title}</h3>
              <p>
                {assessment.kataIds.length} katas
                {assessment.durationMinutes
                  ? ` · ${assessment.durationMinutes} min`
                  : ' · untimed'}
              </p>
              <AssessmentStartActions
                client:load="react"
                assessmentId={assessment.id}
                durationMinutes={assessment.durationMinutes}
                kataIds={assessment.kataIds}
              />
            </li>
          ))}
        </ul>
      </section>

      <section class="landing-section" id="katas">
        <div class="section-header">
          <h2>Practice a Kata</h2>
        </div>
        <ul class="card-list">
          {katas.map((kata) => (
            <li class="card">
              <h3>{kata.title}</h3>
              <p>
                <span class={`badge badge-${kata.difficulty}`}>{kata.difficulty}</span>
                {' '}
                {kata.estimatedMinutes} min
              </p>
              <a class="btn btn-secondary" href={`/problem/${kata.id}`}>
                Open
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>
  </body>
</html>
